---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const tagsCount = {};

// 统计每个标签的出现次数
docs.forEach(doc => {
  if (doc.data.tags) {
    doc.data.tags.forEach(tag => {
      tagsCount[tag] = (tagsCount[tag] || 0) + 1;
    });
  }
});

// 按数量从多到少排序
const sortedTags = Object.entries(tagsCount).sort((a, b) => b[1] - a[1]);
---

<StarlightPage frontmatter={{ title: 'AIPali 智能化巴利三藏 - 标签云', tableOfContents: false, template: 'splash' }}>
  <p>共发现 <strong>{sortedTags.length}</strong> 个独立标签：</p>
  
  <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem;">
    {sortedTags.map(([tag, count]) => (
      <a 
        href={`/tags/${tag}`} 
        style="padding: 0.5rem 1rem; background: var(--sl-color-bg-nav); border-radius: 999px; text-decoration: none; border: 1px solid var(--sl-color-gray-5); color: var(--sl-color-text-accent);"
      >
        {tag} <span style="opacity: 0.6; font-size: 0.8em; margin-left: 0.2rem;">{count}</span>
      </a>
    ))}
  </div>
</StarlightPage>
