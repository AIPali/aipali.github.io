---
// src/components/scripts/GlobalScripts.astro
import CustomScripts from './CustomScripts.astro';
import FastGPT from './FastGPT.astro';
import PaliLookup from './PaliLookup.astro';
import Analytics from './Analytics.astro';
// import GoogleAnalytics from './GoogleAnalytics.astro'; 

const baseUrl = import.meta.env.BASE_URL || '/';
const manifestUrl = `${baseUrl}manifest.webmanifest`.replace(/\/\/+/g, '/');
const swUrl = `${baseUrl}sw.js`.replace(/\/\/+/g, '/');
const iconUrl = `${baseUrl}assets/logo_dark_192x192.png`.replace(/\/\/+/g, '/');
---

<!-- ================= PWA 核心声明 ================= -->
<link rel="manifest" href={manifestUrl} />
<meta name="theme-color" content="#17181c" />

<!-- Apple iOS 专属 PWA 适配 -->
<link rel="apple-touch-icon" href={iconUrl} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="AIPali" />

<!-- 手动注册 Service Worker 保证所有平台 100% 生效 -->
<script define:vars={{ swUrl }}>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register(swUrl)
        .then((registration) => {
          console.log('[AIPali PWA] 注册成功，作用域:', registration.scope);
        })
        .catch((error) => {
          console.error('[AIPali PWA] ❌ 注册失败:', error);
        });
    });
  }
</script>

<!-- ================= 其他全局脚本 ================= -->
<CustomScripts />
<FastGPT />
<PaliLookup />
<Analytics />
<!-- <GoogleAnalytics /> -->