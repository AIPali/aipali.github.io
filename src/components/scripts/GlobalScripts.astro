---
// src/components/scripts/GlobalScripts.astro
import CustomScripts from './CustomScripts.astro';
import FastGPT from './FastGPT.astro';
import PaliLookup from './PaliLookup.astro';
import Analytics from './Analytics.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
const manifestUrl = `${baseUrl}manifest.webmanifest`.replace(/\/\/+/g, '/');
const swUrl = `${baseUrl}sw.js`.replace(/\/\/+/g, '/');
const iconUrl = `${baseUrl}assets/logo_192x192.png`.replace(/\/\/+/g, '/');
---

<!-- 1. PWA Manifest -->
<link rel="manifest" href={manifestUrl} />
<meta name="theme-color" content="#17181c" />

<!-- 2. Apple iOS PWA 适配 (修复了 Deprecated 警告) -->
<link rel="apple-touch-icon" href={iconUrl} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="AIPali" />

<!-- 3. PWA 手动安全注册 -->
<script define:vars={{ swUrl }}>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register(swUrl)
        .then((reg) => {
          console.log('[AIPali PWA] ✅ 注册成功! Scope:', reg.scope);
          reg.onupdatefound = () => {
            const installingWorker = reg.installing;
            if (installingWorker == null) return;
            installingWorker.onstatechange = () => {
              if (installingWorker.state === 'installed' && navigator.serviceWorker.controller) {
                console.log('[AIPali PWA] 🔄 新内容就绪，将在下次启动时生效');
              }
            };
          };
        })
        .catch((err) => console.error('[AIPali PWA] ❌ 注册失败:', err));
    });
  }
</script>

<CustomScripts />
<FastGPT />
<PaliLookup />
<Analytics />