---
import CustomScripts from './CustomScripts.astro';
import FastGPT from './FastGPT.astro';
import PaliLookup from './PaliLookup.astro';
import Analytics from './Analytics.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
const manifestUrl = `${baseUrl}manifest.webmanifest`.replace(/\/\/+/g, '/');
const swUrl = `${baseUrl}sw.js`.replace(/\/\/+/g, '/');
const iconUrl = `${baseUrl}assets/logo_dark_192x192.png`.replace(/\/\/+/g, '/');
const offlineUrl = `${baseUrl}offline/`.replace(/\/\/+/g, '/');
---

<link rel="manifest" href={manifestUrl} />
<meta name="theme-color" content="#17181c" />
<link rel="apple-touch-icon" href={iconUrl} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="AIPali" />

<script define:vars={{ swUrl, baseUrl, offlineUrl }}>
  // PWA Standalone 模式下的路由接管
  if (window.matchMedia('(display-mode: standalone)').matches) {
    
    // 1. 如果因为某些原因回到了纯根目录，平滑替换到 offline
    const path = window.location.pathname;
    if (path === baseUrl || path === baseUrl + 'index.html') {
      window.location.replace(offlineUrl);
    }
    
    // 2. 拦截左上角 Starlight Logo 的点击事件，改写为指向 Offline 控制台，杜绝死循环
    document.addEventListener('DOMContentLoaded', () => {
      const siteTitleAnchor = document.querySelector('.site-title a');
      if (siteTitleAnchor) {
        siteTitleAnchor.setAttribute('href', offlineUrl);
      }
    });
  }

  // 注册 Service Worker
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', async () => {
      if (navigator.storage && navigator.storage.persist) {
        const isPersisted = await navigator.storage.persist();
        console.log(`[AIPali PWA] 数据持久化状态: ${isPersisted ? '已锁定 (防清除)' : '未锁定'}`);
      }
      navigator.serviceWorker.register(swUrl).then((reg) => {
        console.log('[AIPali PWA] 引擎启动，作用域:', reg.scope);
      });
    });
  }
</script>

<CustomScripts />
<FastGPT />
<PaliLookup />
<Analytics />