---
// src/components/scripts/PWA.astro
const baseUrl = import.meta.env.BASE_URL || '/';
const manifestUrl = `${baseUrl}manifest.webmanifest`.replace(/\/\/+/g, '/');
const swUrl = `${baseUrl}sw.js`.replace(/\/\/+/g, '/');
const iconUrl = `${baseUrl}assets/logo_dark_192x192.png`.replace(/\/\/+/g, '/');
const offlineUrl = `${baseUrl}offline/`.replace(/\/\/+/g, '/');
---

<link rel="manifest" href={manifestUrl} />
<meta name="theme-color" content="#17181c" />
<link rel="apple-touch-icon" href={iconUrl} />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="AIPali" />

<script define:vars={{ swUrl, baseUrl, offlineUrl }}>
  // 1. 定义环境常量
  const hostname = window.location.hostname;
  const isTargetDomain = hostname.includes('aipali.github.io') || 
                         hostname === 'localhost' || 
                         hostname === '127.0.0.1' || 
                         hostname.startsWith('192.168.');
                         
  // 2. 检测是否为 PWA 独立应用模式 (桌面/主屏幕 App 打开)
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches || 
                       window.navigator.standalone === true; // 兼容 iOS 老版本

  // 3. 路由守护：如果在独立 App 模式下处于首页，平滑跳转到控制台
  if (isStandalone) {
    const path = window.location.pathname;
    if (path === baseUrl || path === baseUrl + 'index.html') {
      window.location.replace(offlineUrl);
    }
    
    // 拦截左上角 Logo，防止跳出 offline 闭环
    document.addEventListener('DOMContentLoaded', () => {
      const siteTitleAnchor = document.querySelector('.site-title a');
      if (siteTitleAnchor) {
        siteTitleAnchor.setAttribute('href', offlineUrl);
      }
    });
  }

  // 4. Service Worker 动态管理 (解决 PC/非应用模式被劫持缓存的问题)
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', async () => {
      
      // 【条件A】只有在"指定域名" 且 "独立应用模式" 下，才注册 PWA 引擎
      if (isTargetDomain && isStandalone) {
        if (navigator.storage && navigator.storage.persist) {
          const isPersisted = await navigator.storage.persist();
          console.log(`[AIPali PWA] 数据持久化: ${isPersisted ? '已锁定' : '未锁定'}`);
        }
        navigator.serviceWorker.register(swUrl).then((reg) => {
          console.log('[AIPali PWA] 独立应用模式，离线引擎已启动，作用域:', reg.scope);
        });
      } 
      // 【条件B】普通浏览器访问，或者在非目标域名下 -> 主动注销清理 SW
      else {
        navigator.serviceWorker.getRegistrations().then((registrations) => {
          for (let reg of registrations) {
            reg.unregister().then(boolean => {
              if (boolean) console.log('[AIPali PWA] 普通浏览器模式，已注销 Service Worker，恢复正常实时网络');
            });
          }
        });
      }
      
    });
  }
</script>