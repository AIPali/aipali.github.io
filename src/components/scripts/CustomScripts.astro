---
// src/components/scripts/CustomScripts.astro
---
<!-- CustomScripts -->
<script is:inline>

            function setupSafariDocSearchFix() {
              // 1. 仅针对 iOS 平台拦截 (涵盖 iOS Safari, Chrome, Edge 等所有基于 WebKit 的浏览器)
              const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
              if (!isIOS) return;

              // 防止重复绑定
              if (window.__docSearchSafariFixApplied) return;
              window.__docSearchSafariFixApplied = true;

              let savedScrollY = 0;
              let savedUrl = '';

              // 2. 利用【事件捕获阶段】(第三个参数设为 true) 拦截放大镜的点击
              // 这样我们能在 Algolia 官方脚本响应之前抢先执行滚动
              document.addEventListener('click', function(e) {
                const btn = e.target.closest('.DocSearch-Button');
                if (btn && window.scrollY > 0) {
                  savedScrollY = window.scrollY;
                  savedUrl = window.location.href;
                  // 在弹出搜索框之前瞬间将页面拉回顶部，避开 iOS 聚焦 Bug
                  window.scrollTo(0, 0); 
                }
              }, true);

              // 3. 监听 Body 上的 class 变化，判断搜索框是否被关闭
              const observer = new MutationObserver(function(mutations) {
                for (const mutation of mutations) {
                  // DocSearch 开启时会在 body 加上 'DocSearch--active'，关闭时移除
                  if (mutation.attributeName === 'class' && !document.body.classList.contains('DocSearch--active')) {
                    // 稍微延迟，等待页面状态稳定
                    setTimeout(() => {
                      // 如果用户只是关闭了搜索框，或者点击的还是当前页面的锚点，则恢复滚动位置
                      if (savedScrollY > 0 && window.location.href === savedUrl) {
                        window.scrollTo(0, savedScrollY);
                        savedScrollY = 0;
                      }
                    }, 50);
                  }
                }
              });

              observer.observe(document.body, { attributes: true });

              // 4. 兼容 Astro 的 View Transitions 视图过渡特性 (如果启用了的话)
              document.addEventListener('astro:after-swap', () => {
                observer.disconnect();
                observer.observe(document.body, { attributes: true });
              });
            }

            // 确保在 DOM 加载完成后执行
            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', setupSafariDocSearchFix);
            } else {
              setupSafariDocSearchFix();
            }



</script>