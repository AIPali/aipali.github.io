---
// src/components/scripts/FastGPT.astro
---
<script
  is:inline
  id="chatbot-iframe"
  data-bot-src="https://ai.true-dhamma.com/chat/share?shareId=pKlTh130EtoSDdDoPOBjMxzy"
  data-default-open="false"
  data-drag="false"
>
function embedChatbot() {
  const chatBtnId = 'fastgpt-chatbot-button';
  const chatWindowId = 'fastgpt-chatbot-window';
  const script = document.getElementById('chatbot-iframe');
  
  const botSrc = script?.getAttribute('data-bot-src');
  const defaultOpen = script?.getAttribute('data-default-open') === 'true';

  document.body.style.overflow = '';

  if (!botSrc || document.getElementById(chatBtnId)) return;

  // ==========================================
  // 定义动态 SVG 图标 (增加对各大框架强行切换明暗主题的 !important 支持)
  // ==========================================
  const svgOpen = `
    <svg viewBox="0 0 80 80" style="width: 100%; height: 100%; overflow: visible;" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="g-blue" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop stop-color="#4facfe" offset="0%"/><stop stop-color="#00f2fe" offset="100%"/>
        </linearGradient>
      </defs>
      <style>
        .fastgpt-icon { transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
        .fastgpt-icon:hover { transform: scale(1.05); }
        
        /* 默认浅色模式 */
        .fastgpt-bg { fill: #ffffff; stroke: url(#g-blue); stroke-width: 3; stroke-dasharray: 60 30; animation: fastgpt-dash 3s linear infinite; }
        .fastgpt-fg { stroke: #111111; fill: none; stroke-width: 3.5; stroke-linecap: round; stroke-linejoin: round; }
        
        @keyframes fastgpt-dash { to { stroke-dashoffset: 180; } }
        
        /* 1. 系统级别深色模式感知 */
        @media (prefers-color-scheme: dark) {
          .fastgpt-bg { fill: #2b2b3b; }
          .fastgpt-fg { stroke: #ffffff; }
        }
        
        /* 2. 网页强制深色接管 (支持 Tailwind / Astro Starlight 等) */
        html.dark .fastgpt-bg, html[data-theme='dark'] .fastgpt-bg { fill: #2b2b3b !important; }
        html.dark .fastgpt-fg, html[data-theme='dark'] .fastgpt-fg { stroke: #ffffff !important; }

        /* 3. 网页强制浅色接管 (极度关键：强行覆盖系统的深色设定) */
        html.light .fastgpt-bg, html[data-theme='light'] .fastgpt-bg { fill: #ffffff !important; }
        html.light .fastgpt-fg, html[data-theme='light'] .fastgpt-fg { stroke: #111111 !important; }
      </style>
      <g class="fastgpt-icon">
        <path class="fastgpt-bg" d="M40 16C26.7 16 16 26.7 16 40c0 13.3 10.7 24 24 24 4.2 0 8.1-1 11.5-2.8L62 64l-2.8-10.5C62.2 49.6 64 45 64 40c0-13.3-10.7-24-24-24z"/>
        <g class="fastgpt-fg">
          <path d="M29 50 L35 30 L41 50 M31.5 43 L38.5 43" />
          <path d="M49 30 L49 50" />
        </g>
      </g>
    </svg>
  `;

  const svgClose = `
    <svg viewBox="0 0 80 80" style="width: 100%; height: 100%; overflow: visible;" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="g-blue-close" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop stop-color="#4facfe" offset="0%"/><stop stop-color="#00f2fe" offset="100%"/>
        </linearGradient>
      </defs>
      <style>
        .fastgpt-icon { transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
        .fastgpt-icon:hover { transform: scale(1.05); }
        
        .fastgpt-bg-close { fill: #ffffff; stroke: url(#g-blue-close); stroke-width: 3; stroke-dasharray: 60 30; animation: fastgpt-dash 3s linear infinite; }
        .fastgpt-fg-close { stroke: #111111; fill: none; stroke-width: 4.5; stroke-linecap: round; }
        
        @keyframes fastgpt-dash { to { stroke-dashoffset: 180; } }
        
        @media (prefers-color-scheme: dark) {
          .fastgpt-bg-close { fill: #2b2b3b; }
          .fastgpt-fg-close { stroke: #ffffff; }
        }
        
        html.dark .fastgpt-bg-close, html[data-theme='dark'] .fastgpt-bg-close { fill: #2b2b3b !important; }
        html.dark .fastgpt-fg-close, html[data-theme='dark'] .fastgpt-fg-close { stroke: #ffffff !important; }

        html.light .fastgpt-bg-close, html[data-theme='light'] .fastgpt-bg-close { fill: #ffffff !important; }
        html.light .fastgpt-fg-close, html[data-theme='light'] .fastgpt-fg-close { stroke: #111111 !important; }
      </style>
      <g class="fastgpt-icon">
        <circle class="fastgpt-bg-close" cx="40" cy="40" r="24" />
        <path class="fastgpt-fg-close" d="M30 30L50 50M50 30L30 50" />
      </g>
    </svg>
  `;

  // 1. 创建触发按钮
  const ChatBtn = document.createElement('div');
  ChatBtn.id = chatBtnId;
  ChatBtn.style.cssText = 'width: 28px; height: 28px; cursor: pointer; display: flex; align-items: center; justify-content: center; margin-left: 0.75rem; flex-shrink: 0; align-self: center; margin-top: auto; margin-bottom: auto;';

  const ChatBtnDiv = document.createElement('div');
  ChatBtnDiv.style.cssText = 'width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;';
  ChatBtnDiv.innerHTML = defaultOpen ? svgClose : svgOpen;
  ChatBtn.appendChild(ChatBtnDiv);

  let isPlacedInHeader = false;

  // 2. 寻找 sl-doc-search 标签
  const docSearchElement = document.querySelector('sl-doc-search');
  if (docSearchElement) {
    docSearchElement.insertAdjacentElement('afterend', ChatBtn);
    isPlacedInHeader = true;
  } else {
    ChatBtn.style.position = 'fixed';
    ChatBtn.style.bottom = '30px';
    ChatBtn.style.right = '30px'; 
    ChatBtn.style.zIndex = '2147483647';
    document.body.appendChild(ChatBtn);
  }

  // 3. 创建对话框 Iframe
  const iframe = document.createElement('iframe');
  iframe.allow = 'microphone *; *';
  iframe.referrerPolicy = 'no-referrer';
  iframe.id = chatWindowId;
  iframe.src = botSrc;
  iframe.style.cssText = 'border: none; position: fixed; flex-direction: column; justify-content: space-between; box-shadow: rgba(150, 150, 150, 0.2) 0px 10px 30px 0px, rgba(150, 150, 150, 0.2) 0px 0px 0px 1px; width: 375px; height: 667px; max-width: 90vw; border-radius: 0.75rem; display: flex; z-index: 2147483647; overflow: hidden; background-color: #F3F4F6; transition: visibility 0.2s, opacity 0.2s;';
  iframe.style.visibility = defaultOpen ? 'unset' : 'hidden';
  iframe.style.opacity = defaultOpen ? '1' : '0';
  document.body.appendChild(iframe);

  // 4. 计算 Iframe 的弹出位置
  const updateChatWindowPosition = () => {
    const btnRect = ChatBtn.getBoundingClientRect();

    if (isPlacedInHeader) {
      const rightOffset = window.innerWidth - btnRect.right - 60; 
      iframe.style.right = Math.max(16, rightOffset) + 'px';
      iframe.style.bottom = 'unset'; 
      iframe.style.top = (btnRect.bottom + 12) + 'px'; 
      iframe.style.maxHeight = `calc(100vh - ${btnRect.bottom + 24}px)`; 
    } else {
      iframe.style.right = (window.innerWidth - btnRect.right) + 'px';
      iframe.style.top = 'unset';
      iframe.style.bottom = (window.innerHeight - btnRect.top + 12) + 'px';
      iframe.style.maxHeight = `calc(100vh - ${window.innerHeight - btnRect.top + 24}px)`;
    }
  };

  ChatBtn.onclick = () => {
    const isOpening = iframe.style.visibility === 'hidden'; 

    iframe.style.visibility = isOpening ? 'unset' : 'hidden';
    iframe.style.opacity = isOpening ? '1' : '0';
    ChatBtnDiv.innerHTML = isOpening ? svgClose : svgOpen;

    if (isOpening) {
      document.body.style.overflow = 'hidden';
      document.body.style.touchAction = 'none'; 
      updateChatWindowPosition(); 
    } else {
      document.body.style.overflow = '';
      document.body.style.touchAction = '';
    }
  };

  window.addEventListener('resize', () => {
    if (iframe.style.visibility !== 'hidden') {
      updateChatWindowPosition();
    }
  });
  updateChatWindowPosition();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', embedChatbot);
} else {
  embedChatbot();
}

document.addEventListener('astro:page-load', embedChatbot);
</script>