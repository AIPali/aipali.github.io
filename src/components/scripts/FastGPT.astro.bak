---
// src/components/scripts/FastGPT.astro
---
<script
  is:inline
  id="chatbot-iframe"
  data-bot-src="https://ai.true-dhamma.com/chat/share?shareId=pKlTh130EtoSDdDoPOBjMxzy"
  data-default-open="false"
  data-drag="false"
  data-open-icon="data:image/svg+xml;base64,"
  data-close-icon="data:image/svg+xml;base64,"
>
/** 
 * 合并原本 iframe.js 的逻辑
 */
function embedChatbot() {
  const chatBtnId = 'fastgpt-chatbot-button';
  const chatWindowId = 'fastgpt-chatbot-window';
  const script = document.getElementById('chatbot-iframe');
  
  const botSrc = script?.getAttribute('data-bot-src');
  const defaultOpen = script?.getAttribute('data-default-open') === 'true';
  const canDrag = script?.getAttribute('data-drag') === 'true';
  const MessageIcon = script?.getAttribute('data-open-icon');
  const CloseIcon = script?.getAttribute('data-close-icon');

  if (!botSrc || document.getElementById(chatBtnId)) return;

  // 创建按钮
  const ChatBtn = document.createElement('div');
  ChatBtn.id = chatBtnId;
  ChatBtn.style.cssText = 'position: fixed; bottom: 30px; right: 60px; width: 40px; height: 40px; cursor: pointer; z-index: 2147483647; transition: 0.3s;';

  const ChatBtnDiv = document.createElement('img');
  ChatBtnDiv.src = defaultOpen ? CloseIcon : MessageIcon;
  ChatBtnDiv.setAttribute('width', '100%');
  ChatBtnDiv.setAttribute('height', '100%');
  ChatBtnDiv.draggable = false;

  // 创建 Iframe
  const iframe = document.createElement('iframe');
  iframe.allow = 'microphone *; *';
  iframe.referrerPolicy = 'no-referrer';
  iframe.id = chatWindowId;
  iframe.src = botSrc;
  iframe.style.cssText = 'border: none; position: fixed; flex-direction: column; justify-content: space-between; box-shadow: rgba(150, 150, 150, 0.2) 0px 10px 30px 0px, rgba(150, 150, 150, 0.2) 0px 0px 0px 1px; width: 375px; height: 667px; max-width: 90vw; max-height: 85vh; border-radius: 0.75rem; display: flex; z-index: 2147483647; overflow: hidden; left: unset; background-color: #F3F4F6; transition: visibility 0.2s, opacity 0.2s;';
  iframe.style.visibility = defaultOpen ? 'unset' : 'hidden';
  iframe.style.opacity = defaultOpen ? '1' : '0';

  document.body.appendChild(iframe);

  // 这里的 update 逻辑保持原样...
  const updateChatWindowPosition = () => {
    const btn = ChatBtn.getBoundingClientRect();
    iframe.style.right = (window.innerWidth - btn.right) + 'px';
    iframe.style.bottom = (window.innerHeight - btn.top + 10) + 'px';
  };

  ChatBtn.onclick = () => {
    const isHidden = iframe.style.visibility === 'hidden';
    iframe.style.visibility = isHidden ? 'unset' : 'hidden';
    iframe.style.opacity = isHidden ? '1' : '0';
    ChatBtnDiv.src = isHidden ? CloseIcon : MessageIcon;
  };

  ChatBtn.appendChild(ChatBtnDiv);
  document.body.appendChild(ChatBtn);
  
  // 初始化位置
  window.addEventListener('resize', updateChatWindowPosition);
  updateChatWindowPosition();
}

// 确保在加载时运行
if (document.readyState === 'complete') {
  embedChatbot();
} else {
  window.addEventListener('load', embedChatbot);
}
</script>