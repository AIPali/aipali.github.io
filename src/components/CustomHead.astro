---
// src/components/CustomHead.astro
import DefaultHead from '@astrojs/starlight/components/Head.astro';
import type { Props } from '@astrojs/starlight/props';
---

<!-- 1. 首先渲染 Starlight 默认的头部元素（SEO、CSS、Title等） -->
<DefaultHead {...Astro.props} />

<!-- 2. 下面是你所有的自定义统计代码 -->

<!-- Baidu tag -->
<script is:inline>
var _hmt = _hmt ||[];
(function() {
  var hm = document.createElement("script");
  hm.src = "https://hm.baidu.com/hm.js?8e011a93010c7c8768cdc64bc31cbc41";
  var s = document.getElementsByTagName("script")[0]; 
  s.parentNode.insertBefore(hm, s);
})();
</script>

<!-- Umami tag -->
<script is:inline defer src="https://analytics.true-dhamma.com/script.js" data-website-id="7599ab69-d5dd-4759-9a9a-8cce67a1fe70"></script>

<!-- Google tag (gtag.js) -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-0QKR2G4G79"></script>
<script is:inline>
  window.dataLayer = window.dataLayer ||[];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-0QKR2G4G79');
</script>

<!-- Clarity tag -->
<script is:inline type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "u1wlw4o0z3");
</script>